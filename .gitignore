# Machine-specific settings (permissions, MCP tools)
settings.local.json

# OS
.DS_Store

# Skill runtime data (may contain auth state)
**/data/browser_state/
**/auth_info.json
**/library.json
**/state.json

# Credentials and secrets
.env*
credentials.json
token.json
keyfile.json
*.pem
*.key
*.p12
*.pfx
*.jks
id_rsa
id_ed25519
.npmrc
.pypirc

# Project dispatch artifacts (historical)
projects/**/sprints/
projects/**/*.pid

# Runtime artifacts
node_modules/
__pycache__/
*.pyc
*.log
*.bak
*.swp
*.tmp
*.sqlite
*.db

# Transient review-gate sentinels written by scripts/implement-review-gate.sh
# (ephemeral per-run verdict files — should never be committed)
.review-verdict-*

# pr-preflight gate sentinel (15-min-fresh marker written on PASS;
# consumed by ~/.claude/hooks/pr-preflight-gate.sh — never committed)
.pr-preflight-passed
